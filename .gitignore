# ========================================
# 資安與機密檔案 (Security) - 極度重要！
# ========================================
# 忽略所有環境變數設定檔，確保資料庫密碼不外洩
.env
.env.*
!.env.example
*.pem

# ========================================
# 編輯器與作業系統 (Editor & OS)
# ========================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ========================================
# 後端：Go (Backend)
# ========================================
# 編譯後的二進制執行檔
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# 測試與覆蓋率輸出
*.test
*.out
coverage.txt

# Go 工作區設定 (通常只在本地使用)
go.work
go.work.sum

# 依賴套件 (Go Modules 時代通常不把 vendor 推上雲端)
vendor/

# ========================================
# 前端：Vue / Node.js (Frontend)
# ========================================
# npm 或 yarn 依賴套件庫 (絕對不能進版控，檔案太大了)
node_modules/

# Vue 專案 build 之後的輸出資料夾
dist/
dist-ssr/

# 前端錯誤日誌檔
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 前端暫存檔
.eslintcache
.stylelintcache